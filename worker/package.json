{
  "name": "shopee-worker",
  "version": "1.0.0",
  "description": "Shopee batch processing worker — runs cron jobs for 294+ shops",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "deploy": "npm run build && pm2 restart shopee-worker",
    "test:api": "ts-node src/test-api.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "bottleneck": "^2.19.5",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
