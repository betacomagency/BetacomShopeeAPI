# Supabase Edge Functions Environment Variables
# Copy file này thành .env và điền thông tin

# Shopee API credentials (giống với frontend)
SHOPEE_PARTNER_ID=123456
SHOPEE_PARTNER_KEY=your_partner_key_here

# Shopee API Base URL
# Production: https://partner.shopeemobile.com
# Sandbox: https://partner.test-stable.shopeemobile.com
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# CORS - Allowed origin for Edge Functions (restrict in production)
ALLOWED_ORIGIN=https://your-app-domain.com

# Admin roles allowed to create users / call partner-level APIs (comma-separated)
ADMIN_ROLES=super_admin,admin
